# ──────────────────────────────────────────────────────────────────
# apps/api — Express backend
# Copy this file to apps/api/.env and fill in real values.
# ──────────────────────────────────────────────────────────────────

# ── Database (Neon) ───────────────────────────────────────────────
# Source: https://console.neon.tech → project → connection details
# DATABASE_URL = pooled connection string (used by Prisma at runtime)
# DIRECT_URL   = direct (unpooled) string (required by Prisma migrations)
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST.neon.tech/neondb?sslmode=require"

# ── Clerk (JWT verification) ──────────────────────────────────────
# Source: https://dashboard.clerk.com → your app → API Keys
# Use the SAME secret as apps/web/.env.local
CLERK_SECRET_KEY="sk_test_..."

# ── Studio scoping ────────────────────────────────────────────────
# Single-tenant: the API only accepts JWTs whose org_id matches this value.
# Source: Clerk dashboard → Organizations → your org → copy ID (org_...)
STUDIO_ORG_ID="org_..."

# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# CORS allow-list for the web app
# Local: http://localhost:3000
# Prod:  https://your-web.vercel.app
WEB_URL="http://localhost:3000"
